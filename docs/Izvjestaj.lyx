\begin_layout Subsection
Matrica incidencije
\end_layout

\begin_layout Standard
Matrica incidencije 
\begin_inset Formula $A$
\end_inset

 dimenzije (broj grana) × (broj čvorova) opisuje topologiju mreže: element
 
\begin_inset Formula $A_{k,i}$
\end_inset

 jednak je 
\begin_inset Formula $+1$
\end_inset

 ako grana 
\begin_inset Formula $k$
\end_inset

 počinje u čvoru 
\begin_inset Formula $i$
\end_inset

, 
\begin_inset Formula $-1$
\end_inset

 ako u njemu završava, i 
\begin_inset Formula $0$
\end_inset

 inače.
 Implementirana je preko 
\family typewriter
dense::DblMatrix
\family default
 (gusta matrica), jer je po prirodi mala i rijetko dominantno popunjena
 nulama u odnosu na Ybus matricu.
\end_layout

\begin_layout Subsection
Jednofazni (pozitivna sekvenca) ekvivalent
\end_layout

\begin_layout Standard
Kao polazna, jednostavnija provjera ispravnosti modela, za svaku granu
 se računa serijska admitansa iz direktne sekvencijalne impedanse:
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
y_{serija}=\frac{1}{Z_{1}}=\frac{1}{R_{1}+jX_{1}}
\]

\end_inset


\end_layout

\begin_layout Standard
Standardnom formulom za formiranje admitantne matrice mreže, za granu između
 čvorova 
\begin_inset Formula $i$
\end_inset

 i 
\begin_inset Formula $j$
\end_inset

:
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
Y_{bus}(i,i) & \mathrel{+}= y_{serija}+\frac{y_{shunt}}{2}\\
Y_{bus}(j,j) & \mathrel{+}= y_{serija}+\frac{y_{shunt}}{2}\\
Y_{bus}(i,j) & \mathrel{-}= y_{serija}\\
Y_{bus}(j,i) & \mathrel{-}= y_{serija}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
gdje je 
\begin_inset Formula $y_{shunt}=jB_{1}$
\end_inset

 poprečna (shunt) susceptansa voda.
 Ovaj model tretira svaki čvor kao jednu (skalarnu) veličinu i ne razlikuje
 faze — koristi se kao brza provjera ispravnosti topologije prije prelaska
 na puni trofazni model.
\end_layout

\begin_layout Subsection
Trofazni (ABC) model
\end_layout

\begin_layout Standard
Puni model predstavlja svaki čvor sa 
\series bold
tri
\series default
 veličine (faze A, B, C), pa Ybus matrica postaje dimenzije 
\begin_inset Formula $3N\times3N$
\end_inset

 (N — broj čvorova), sastavljena od 
\begin_inset Formula $3\times3$
\end_inset

 blokova po paru čvorova.
 Fazna (ABC) impedantna matrica voda izvodi se iz direktne (
\begin_inset Formula $Z_{1}$
\end_inset

) i nulte (
\begin_inset Formula $Z_{0}$
\end_inset

) sekvencijalne impedanse standardnom transformacijom simetričnih komponenti,
 uz pretpostavku transponovanog (fizički simetričnog) voda:
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
Z_{s}=\frac{Z_{0}+2Z_{1}}{3}\qquad Z_{m}=\frac{Z_{0}-Z_{1}}{3}
\]

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
Z_{ABC}=\begin{bmatrix}Z_{s} & Z_{m} & Z_{m}\\
Z_{m} & Z_{s} & Z_{m}\\
Z_{m} & Z_{m} & Z_{s}
\end{bmatrix}
\]

\end_inset


\end_layout

\begin_layout Standard
Pošto je 
\begin_inset Formula $Z_{ABC}$
\end_inset

 cirkulantna matrica, njena inverzija (admitantna matrica) ima identičnu
 strukturu i može se izračunati direktno preko sekvencijalnih admitansi,
 bez eksplicitne inverzije matrice:
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
Y_{1}=\frac{1}{Z_{1}}\qquad Y_{0}=\frac{1}{Z_{0}}
\]

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
Y_{s}=\frac{Y_{0}+2Y_{1}}{3}\qquad Y_{m}=\frac{Y_{0}-Y_{1}}{3}\qquad Y_{ABC}=\begin{bmatrix}Y_{s} & Y_{m} & Y_{m}\\
Y_{m} & Y_{s} & Y_{m}\\
Y_{m} & Y_{m} & Y_{s}
\end{bmatrix}
\]

\end_inset


\end_layout

\begin_layout Standard
Kada je vod savršeno simetričan (
\begin_inset Formula $Z_{0}=Z_{1}$
\end_inset

), slijedi 
\begin_inset Formula $Y_{m}=0$
\end_inset

 i faze se potpuno razdvajaju — model se svodi na tri nezavisna jednofazna
 kruga.
 Nesimetrija u praksi (različita struja/napon po fazama) tada dolazi isključivo
 od neravnomjernog opterećenja po fazama, a ne od same impedanse voda —
 što je uobičajena i prihvatljiva aproksimacija za distributivne mreže
 sa transponovanim (ili približno simetričnim) vodovima.
\end_layout

\begin_layout Standard
Za transformator katalog ne sadrži zasebnu nultu sekvencu (zavisi od grupe
 spoja), pa je u trenutnoj verziji modela usvojeno pojednostavljenje: faze
 transformatora se tretiraju kao međusobno nezavisne (
\begin_inset Formula $Y_{m}=0$
\end_inset

), sa jednakom serijskom admitansom na sve tri faze, izračunatom iz napona
 kratkog spoja i gubitaka u bakru.
 Ovo je jasno naznačeno kao pojednostavljenje i predstavlja prirodan pravac
 daljeg unaprjeđenja (poglavlje 
\begin_inset space ~
\end_inset


\begin_inset CommandInset ref
LatexCommand ref
reference "sec:Zakljucak"

\end_inset

).
\end_layout

\begin_layout Standard
Ugrađivanje 
\begin_inset Formula $3\times3$
\end_inset

 bloka grane između čvorova 
\begin_inset Formula $i$
\end_inset

 i 
\begin_inset Formula $j$
\end_inset

 u punu 
\begin_inset Formula $3N\times3N$
\end_inset

 matricu vrši se analogno jednofaznom slučaju, primijenjeno na svaki par
 faza 
\begin_inset Formula $(p,q)\in\{A,B,C\}$
\end_inset

:
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
Y_{bus}(3i+p,\,3i+q) & \mathrel{+}=Y_{ABC}(p,q)+\frac{Y_{shunt}(p,q)}{2}\\
Y_{bus}(3j+p,\,3j+q) & \mathrel{+}=Y_{ABC}(p,q)+\frac{Y_{shunt}(p,q)}{2}\\
Y_{bus}(3i+p,\,3j+q) & \mathrel{-}=Y_{ABC}(p,q)\\
Y_{bus}(3j+p,\,3i+q) & \mathrel{-}=Y_{ABC}(p,q)
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
Ova matrica se gradi kroz natID 
\family typewriter
sparse::IMatrix
\family default
